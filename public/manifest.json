{
  "manifest_version": 3,
  "name": "JSON Formatter & Editor",
  "version": "1.0.0",
  "description": "Format, validate, and edit JSON with Monaco Editor. 100% offline.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JSON Formatter & Editor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' blob:; worker-src blob: 'self'; object-src 'self'"
  }
}
